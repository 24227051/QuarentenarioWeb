<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuarentenarioWeb</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/favicon.png" />

    <!-- Bootswatch theme (Cosmo) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/cosmo/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-papZy..." crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuarentenarioWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
@*                 <a class="navbar-brand d-flex align-items-center" asp-area="" asp-page="/Index">
                    <img src="~/images/logo-sm.png" alt="Logo" style="height:28px; margin-right:8px;" />
                    QuarentenarioWeb
                </a> *@
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav" aria-controls="topNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="topNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Analises/Index">Análises</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Anexos/Index">Anexos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Clientes/Index">Clientes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Materiais/Index">Materiais</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Patogenos/Index">Patógenos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/TiposControle/Index">Tipos Controle</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/TiposPatogeno/Index">Tipos Patógeno</a></li>
                    </ul>

@*                     <form class="d-flex me-2" role="search" method="get" asp-page="/Search">
                        <input class="form-control form-control-sm me-2" name="q" type="search" placeholder="Buscar" aria-label="Buscar">
                        <button class="btn btn-sm btn-outline-light" type="submit"><i class="fa fa-search"></i></button>
                    </form> *@

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-3 bg-light border-top">
        <div class="container text-center">
            <small class="text-muted">&copy; 2026 - QuarentenarioWeb</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
