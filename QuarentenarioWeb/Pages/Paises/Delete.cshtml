@page
@model QuarentenarioWeb.Pages.Paises.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir</h1>

<h3>Tem certeza de que deseja excluir isso?</h3>
<div>
    <h4>País</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Pais.Nome)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Pais.Nome)
        </dd>
    </dl>
    
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="Pais.Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-page="./Index">Voltar à lista</a>
    </form>
</div>
