@page
@model QuarentenarioWeb.Pages.AnalisesDetalhes.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="./Create" asp-route-id="@Model.IdAnalise">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].Descricao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].DataInicio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].DataTermino)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].Finalizada)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].IdAnaliseNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnaliseDetalhe[0].IdPatogenoNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.AnaliseDetalhe) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Descricao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataInicio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataTermino)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Finalizada)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdAnaliseNavigation.Descricao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdPatogenoNavigation.Nome)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a> |
                <a asp-page="../Anexos/Index" asp-route-idAnaliseDetalhe="@item.Id">Anexos</a>
            </td>
        </tr>
}
    </tbody>
</table>
