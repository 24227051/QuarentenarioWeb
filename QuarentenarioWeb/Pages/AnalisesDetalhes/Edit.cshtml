@page
@model QuarentenarioWeb.Pages.AnalisesDetalhes.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar</h1>

<h4>Controle</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AnaliseDetalhe.Id" />
            <div class="form-group">
                <label class="control-label">Analise</label>
                <div class="form-control-plaintext">@Model.AnaliseDescricao (@Model.AnaliseDetalhe.IdAnalise)</div>
                <input type="hidden" asp-for="AnaliseDetalhe.IdAnalise" />
            </div>
            <div class="form-group">
                <label asp-for="AnaliseDetalhe.IdPatogeno" class="control-label"></label>
                <select asp-for="AnaliseDetalhe.IdPatogeno" class="form-control" asp-items="ViewBag.IdPatogeno" >
                    <option value="">-- Selecione um Patógeno --</option>
                </select>
                <span asp-validation-for="AnaliseDetalhe.IdPatogeno" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AnaliseDetalhe.Descricao" class="control-label"></label>
                <input asp-for="AnaliseDetalhe.Descricao" class="form-control" />
                <span asp-validation-for="AnaliseDetalhe.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AnaliseDetalhe.DataInicio" class="control-label"></label>
                <input asp-for="AnaliseDetalhe.DataInicio" class="form-control" />
                <span asp-validation-for="AnaliseDetalhe.DataInicio" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AnaliseDetalhe.DataTermino" class="control-label"></label>
                <input asp-for="AnaliseDetalhe.DataTermino" class="form-control" />
                <span asp-validation-for="AnaliseDetalhe.DataTermino" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AnaliseDetalhe.Finalizada" /> @Html.DisplayNameFor(model => model.AnaliseDetalhe.Finalizada)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index" asp-route-id="@Model.AnaliseDetalhe.IdAnalise">Voltar à lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
