@page
@model QuarentenarioWeb.Pages.Patogenos.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Patogeno</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Patogeno.Id" />
            <div class="form-group">
                <label asp-for="Patogeno.Nome" class="control-label"></label>
                <input asp-for="Patogeno.Nome" class="form-control" />
                <span asp-validation-for="Patogeno.Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Patogeno.IdTipoPatogeno" class="control-label"></label>
                <select asp-for="Patogeno.IdTipoPatogeno" class="form-control" asp-items="ViewBag.IdTipoPatogeno" ></select>
                <span asp-validation-for="Patogeno.IdTipoPatogeno" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Patogeno.IdTipoControle" class="control-label"></label>
                <select asp-for="Patogeno.IdTipoControle" class="form-control" asp-items="ViewBag.IdTipoControle" ></select>
                <span asp-validation-for="Patogeno.IdTipoControle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
