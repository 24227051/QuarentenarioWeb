@page
@model QuarentenarioWeb.Pages.Anexos.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir</h1>

<h3>Tem certeza de que deseja excluir isso?</h3>
<div>
    <h4>Anexo</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Anexo.NomeArquivo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Anexo.NomeArquivo)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Anexo.NomeArmazenado)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Anexo.NomeArmazenado)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Anexo.TipoConteudo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Anexo.TipoConteudo)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Anexo.IdAnaliseDetalheNavigation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Anexo.IdAnaliseDetalheNavigation.Descricao)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Anexo.IdAnaliseNavigation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Anexo.IdAnaliseNavigation.Descricao)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Anexo.Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-page="./Index" asp-route-idAnalise="@Model.Anexo.IdAnalise" asp-route-idAnaliseDetalhe="@Model.Anexo.IdAnaliseDetalhe">Voltar à lista</a>
    </form>
</div>
