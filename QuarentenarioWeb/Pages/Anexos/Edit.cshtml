@page
@model QuarentenarioWeb.Pages.Anexos.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Anexo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Anexo.Id" />
            <div class="form-group">
                <label asp-for="Anexo.NomeArquivo" class="control-label"></label>
                <input asp-for="Anexo.NomeArquivo" class="form-control" />
                <span asp-validation-for="Anexo.NomeArquivo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Anexo.NomeArmazenado" class="control-label"></label>
                <input asp-for="Anexo.NomeArmazenado" class="form-control" />
                <span asp-validation-for="Anexo.NomeArmazenado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Anexo.TipoConteudo" class="control-label"></label>
                <input asp-for="Anexo.TipoConteudo" class="form-control" />
                <span asp-validation-for="Anexo.TipoConteudo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Anexo.IdAnalise" class="control-label"></label>
                <select asp-for="Anexo.IdAnalise" class="form-control" asp-items="ViewBag.IdAnalise" ></select>
                <span asp-validation-for="Anexo.IdAnalise" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Anexo.IdAnaliseDetalhe" class="control-label"></label>
                <select asp-for="Anexo.IdAnaliseDetalhe" class="form-control" asp-items="ViewBag.IdAnaliseDetalhe" ></select>
                <span asp-validation-for="Anexo.IdAnaliseDetalhe" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
