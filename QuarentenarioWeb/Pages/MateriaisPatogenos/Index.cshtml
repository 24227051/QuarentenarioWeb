@page
@model QuarentenarioWeb.Pages.MateriaisPatogenos.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create" asp-route-idMaterial="@Model.IdMaterial">Criar Novo</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Material</th>
            <th>
                @Html.DisplayNameFor(model => model.Patogenos[0].Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Patogenos[0].IdTipoControleNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Patogenos[0].IdTipoPatogenoNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Patogenos)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => model.Material!.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdTipoControleNavigation.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdTipoPatogenoNavigation.Nome)
                </td>
                <td>
                    <a asp-page="./Delete" asp-route-idPatogeno="@item.Id" asp-route-idMaterial="@Model.IdMaterial">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
