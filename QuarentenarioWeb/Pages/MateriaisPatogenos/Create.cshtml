@page "{idMaterial:int}"
@model QuarentenarioWeb.Pages.MateriaisPatogenos.CreateModel

@{
    ViewData["Title"] = "Create";
}
        
<h1>Create</h1>
        
<h4>Material / Patógeno</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label class="control-label">Analise</label>
                <div class="form-control-plaintext">@Model.Material!.Nome (@Model.Material.Id)</div>
                <input type="hidden" asp-for="Material.Id" />
            </div>
            <div class="form-group">
                <label asp-for="SelectedPatogenoId" class="control-label"></label>
                <select asp-for="SelectedPatogenoId" class="form-control" asp-items="@(ViewData["IdPatogeno"] as SelectList)">
                    <option value="">-- Selecione um Patógeno --</option>
                </select>
                <span asp-validation-for="SelectedPatogenoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index" asp-route-id="@Model.Material!.Id">Voltar à lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
